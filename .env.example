# =============================================================================
# Cognee-AI-DM environment template
# Copy to .env and fill in your keys. Never commit .env.
# =============================================================================

# --- Cognee's internal LLM (used for graph extraction + recall completion) ---
# Groq llama-3.3-70b via LLMProvider.CUSTOM. Free tier at console.groq.com.
LLM_PROVIDER=custom
LLM_MODEL=groq/llama-3.3-70b-versatile
LLM_ENDPOINT=https://api.groq.com/openai/v1
LLM_API_KEY=your-groq-key-here
LLM_INSTRUCTOR_MODE=json_mode

# --- Cognee's embeddings (local, no key needed) ---
EMBEDDING_PROVIDER=fastembed
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIMENSIONS=384

# --- Cognee runtime flags ---
ENABLE_BACKEND_ACCESS_CONTROL=false
COGNEE_SKIP_CONNECTION_TEST=true

# --- Narration LLM (dm.py, separate from Cognee's internal LLM) ---
# Default: Groq. Switch to Anthropic by setting NARRATION_PROVIDER=anthropic.
NARRATION_PROVIDER=groq
NARRATION_MODEL=llama-3.3-70b-versatile
NARRATION_BASE_URL=https://api.groq.com/openai/v1
NARRATION_API_KEY=your-groq-key-here

# Optional: Anthropic key for Claude narration.
# ANTHROPIC_API_KEY=sk-ant-api03-...

# --- Memory backend ---
# local  = Cognee runs locally with fastembed embeddings
# cloud  = ships every recall/remember to Cognee Cloud (platform.cognee.ai)
MEMORY_BACKEND=local

# --- Cognee Cloud (only used when MEMORY_BACKEND=cloud) ---
# Get these at platform.cognee.ai after signing up.
# Use code COGNEE-35 at signup for $35 free credit.
COGNEE_SERVICE_URL=https://tenant-<your-tenant-id>.aws.cognee.ai
COGNEE_API_KEY=your-cognee-cloud-key-here
CLOUD_DATASET=ravenhollow
